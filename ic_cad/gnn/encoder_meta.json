{
  "method": "GRACE",
  "hidden_dim": 64,
  "num_layers": 2,
  "dropout": 0.3,
  "epochs": 250,
  "learning_rate": 0.001,
  "weight_decay": 0.0005,
  "separate_training": false,
  "feature_dim": 23,
  "model_file": "final.pt",
  "seed": 42,
  "benchmarks": [
    "des",
    "aes",
    "ac97_top",
    "aes_cipher_top"
  ],
  "probe_every": 10,
  "probe_samples": 30000,
  "earlystop_by_probe": false,
  "probe_graph": "",
  "fix_probe_samples": false,
  "final_probe_average": 0,
  "heads_schedule": [
    1,
    1
  ],
  "tau": 0.3,
  "feat_mask": 0.1,
  "edge_drop": 0.1,
  "use_proj": true,
  "proj_dim": 128,
  "cell_embed_dim": 8,
  "batch_size": 1,
  "gradient_accumulation": 4,
  "nce_chunk": 768,
  "scheduler_type": "plateau",
  "scheduler_patience": 10,
  "scheduler_factor": 0.7
}